# Evolution API v2
EVOLUTION_INSTANCE=minha-instancia
EVOLUTION_API_KEY=sua-api-key-da-instancia
EVOLUTION_BASE_URL=https://evolution.seudominio.com.br

# Gateway (servidor separado)
GATEWAY_URL=ws://ip-do-gateway:18789
GATEWAY_SECRET=mesmo-secret-do-gateway

# Webhook (porta que a Evolution vai chamar)
WEBHOOK_PORT=3001

# Workspace Capyra
WORKSPACE=default

# Log
LOG_LEVEL=info